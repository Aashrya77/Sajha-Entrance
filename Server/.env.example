# MongoDB
MONGODB_URI=mongodb://localhost:27017/sajha-web
SESSION_SECRET=replace_with_a_long_random_secret

# Server
PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
# Legacy fallback if older local scripts still use STATE. Prefer NODE_ENV.
# STATE=development

# JWT
JWT_SECRET=your_jwt_secret_here

# eSewa Payment Gateway
# For testing: EPAYTEST / 8gBm/:&EnhH.1/q
# For production: Your actual merchant code and secret key from eSewa
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_ENVIRONMENT=test
# Set ESEWA_ENVIRONMENT=production when going live

# Email (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
