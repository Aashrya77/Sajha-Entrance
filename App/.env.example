# Example environment variables for the Vite frontend app
# Replace the value below with your actual Google Analytics measurement ID.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# WhatsApp number used by bookstore "Inquire Now" links. Include country code.
VITE_WHATSAPP_NUMBER=9779860688212

# You can add other Vite env variables here as needed.
# For example:
# VITE_API_BASE_URL=http://localhost:5000/api
# VITE_ADMIN_URL=http://localhost:5000/sajha-admin
